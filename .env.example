# ============================================================
# n8n-automation-lab — Template variabili d'ambiente
# ============================================================
# Copia questo file in .env e sostituisci i valori con i tuoi.
# NON committare mai il file .env su GitHub.
# ============================================================

# -- n8n Instance --
N8N_HOST=http://localhost:5678          # URL della tua istanza n8n

# -- Google Gemini API --
# Usata nel workflow Progetto1 (nodo HTTP Request, autenticazione httpQueryAuth)
# Ottieni la chiave su: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# -- Workflow: Consulenza --
# ID del foglio Google Sheets dove vengono registrate le prenotazioni
# Trovalo nell'URL del foglio: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
CONSULENZA_SPREADSHEET_ID=your_spreadsheet_id_here

# -- Workflow: Progetto1 --
# ID della cartella Google Drive dove vengono salvate le immagini generate
# Trovalo nell'URL della cartella su Drive: drive.google.com/drive/folders/FOLDER_ID
PROGETTO1_DRIVE_FOLDER_ID=your_drive_folder_id_here
