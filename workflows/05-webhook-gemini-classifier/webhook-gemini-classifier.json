    {
      "parameters": {
        "jsCode": "const VALID_CATEGORIES = ['informational', 'transactional', 'error', 'alert', 'other'];\n\n// Estrae i campi di contesto dallo stato precedente del workflow\nconst receivedAt = $input.first().json.received_at || new Date().toISOString();\nconst payloadRaw = $input.first().json.payload_raw || '';\nconst truncated = Boolean($input.first().json.truncated);\nconst retryCount = $input.first().json.retry_count || 0;\n\n// Estrae il testo dalla risposta Gemini\nlet rawText = '';\ntry {\n  const body = $input.first().json.body || $input.first().json;\n  rawText = body.candidates[0].content.parts[0].text;\n  rawText = rawText.replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '').replace(/```\\s*$/, '').trim();\n} catch (e) {\n  return [{\n    json: {\n      _parseOk: false,\n      _parseError: true,\n      error_type: 'parse_error',\n      error_message: 'Cannot extract text from Gemini response: ' + e.message,\n      original: JSON.stringify($input.first().json),\n      received_at: receivedAt,\n      payload_raw: payloadRaw,\n      retry_count: retryCount,\n      truncated: truncated\n    }\n  }];\n}\n\n// Tenta il parsing JSON\nlet parsed;\ntry {\n  parsed = JSON.parse(rawText);\n} catch (_) {\n  return [{\n    json: {\n      _parseOk: false,\n      _parseError: true,\n      error_type: 'parse_error',\n      error_message: 'Gemini response is not valid JSON',\n      original: rawText,\n      received_at: receivedAt,\n      payload_raw: payloadRaw,\n      retry_count: retryCount,\n      truncated: truncated\n    }\n  }];\n}\n\n// Validazione\nconst { category, confidence, summary } = parsed || {};\n\nif (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n  return [{ json: { _parseOk: false, _parseError: true, error_type: 'parse_error', error_message: 'Parsed result is not an object', original: rawText, received_at: receivedAt, payload_raw: payloadRaw, retry_count: retryCount, truncated: truncated } }];\n}\nif (typeof category !== 'string' || !VALID_CATEGORIES.includes(category)) {\n  return [{ json: { _parseOk: false, _parseError: true, error_type: 'parse_error', error_message: 'Invalid category: ' + category, original: rawText, received_at: receivedAt, payload_raw: payloadRaw, retry_count: retryCount, truncated: truncated } }];\n}\nif (typeof confidence !== 'number' || !isFinite(confidence) || confidence < 0 || confidence > 1) {\n  return [{ json: { _parseOk: false, _parseError: true, error_type: 'parse_error', error_message: 'Invalid confidence: ' + confidence, original: rawText, received_at: receivedAt, payload_raw: payloadRaw, retry_count: retryCount, truncated: truncated } }];\n}\nif (typeof summary !== 'string' || summary.length > 200) {\n  return [{ json: { _parseOk: false, _parseError: true, error_type: 'parse_error', error_message: 'Invalid summary length: ' + (summary ? summary.length : 'undefined'), original: rawText, received_at: receivedAt, payload_raw: payloadRaw, retry_count: retryCount, truncated: truncated } }];\n}\n\nreturn [{\n  json: {\n    category: category,\n    confidence: confidence,\n    summary: summary,\n    received_at: receivedAt,\n    payload_raw: payloadRaw,\n    truncated: truncated,\n    retry_count: retryCount,\n    _parseOk: true\n  }\n}];"
      },
