      "parameters": {
        "jsCode": "// Code_ValidateTruncate — adattato per n8n Code node v2\n// In n8n il webhook espone body in $json.body e header in $json.headers\nconst body = $input.first().json.body;\nconst headers = $input.first().json.headers || {};\nconst contentType = (headers['content-type'] || headers['Content-Type'] || '').toLowerCase();\nconst receivedAt = $input.first().json.received_at;\nconst retryCount = $input.first().json.retry_count || 0;\n\n// Requirement 1.6: controlla Content-Type\nif (!contentType.includes('application/json')) {\n  return [{\n    json: {\n      statusCode: 415,\n      body: { error: 'unsupported_media_type' },\n      _error: true,\n      _errorCode: 415\n    }\n  }];\n}\n\n// Requirement 2.2: valida che il body sia un oggetto JSON (non null, non stringa)\nif (body === null || body === undefined) {\n  return [{\n    json: {\n      statusCode: 400,\n      body: { error: 'invalid_payload', detail: 'Body is null or undefined' },\n      _error: true,\n      _errorCode: 400\n    }\n  }];\n}\n\nif (typeof body === 'string') {\n  return [{\n    json: {\n      statusCode: 400,\n      body: { error: 'invalid_payload', detail: 'Body is a string, not an object' },\n      _error: true,\n      _errorCode: 400\n    }\n  }];\n}\n\nif (typeof body !== 'object') {\n  return [{\n    json: {\n      statusCode: 400,\n      body: { error: 'invalid_payload', detail: `Body is ${typeof body}, not an object` },\n      _error: true,\n      _errorCode: 400\n    }\n  }];\n}\n\n// Requirement 2.4, 2.5: serializza e tronca a 10000 se necessario\nlet payloadRaw = JSON.stringify(body);\nlet truncated = false;\n\nif (payloadRaw.length > 10000) {\n  payloadRaw = payloadRaw.substring(0, 10000);\n  truncated = true;\n}\n\n// Caso ok: restituisce il payload arricchito con received_at e retry_count\nreturn [{\n  json: {\n    payload: body,\n    payload_raw: payloadRaw,\n    received_at: receivedAt,\n    retry_count: retryCount,\n    truncated: truncated,\n    _error: false\n  }\n}];"
      },
