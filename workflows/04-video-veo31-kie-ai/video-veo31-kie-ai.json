    {
      "parameters": {
        "jsCode": "// Legge i byte reali del file binario dal filesystem interno di n8n\n// (necessario con binaryMode 'separate': item.binary[key].data NON contiene il base64)\nconst items = [];\n\nfor (let i = 0; i < $input.all().length; i++) {\n  const item = $input.all()[i];\n  const binaryKeys = Object.keys(item.binary || {});\n\n  if (binaryKeys.length === 0) {\n    items.push({\n      json: {\n        ...item.json,\n        error_debug: \"Nessun dato binario trovato. Assicurati di aver eseguito il Form Trigger con un file caricato.\"\n      }\n    });\n    continue;\n  }\n\n  const firstKey = binaryKeys[0];\n  const buffer = await this.helpers.getBinaryDataBuffer(i, firstKey);\n  const base64 = buffer.toString('base64');\n  const mimeType = item.binary[firstKey].mimeType;\n\n  items.push({\n    json: {\n      ...item.json,\n      base64_string: base64,\n      mime_type: mimeType,\n      original_field_name: firstKey\n    }\n  });\n}\n\nreturn items;"
      },
